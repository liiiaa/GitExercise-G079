import pygame
import sys
import os
import random

# ==================================================
# INITIALIZATION
# ==================================================
pygame.init()
WIDTH, HEIGHT = 1280, 720
screen = pygame.display.set_mode((WIDTH, HEIGHT), pygame.RESIZABLE)
pygame.display.set_caption("A Scoop of Spring")
clock = pygame.time.Clock()

# ==================================================
# PATHS & LOADER
# ==================================================
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
PARENT_DIR = os.path.dirname(SCRIPT_DIR)
ASSETS_PATH = os.path.join(PARENT_DIR, "Assets", "Main Game Assets")

def load_img(name, size):
    path = os.path.join(ASSETS_PATH, name)
    try:
        img = pygame.image.load(path).convert_alpha()
        return pygame.transform.scale(img, size)
    except:
        surf = pygame.Surface(size)
        surf.fill((255, 0, 255))
        return surf

# ==================================================
# ASSETS
# ==================================================
bg_img = load_img("Game Background.png", (WIDTH, HEIGHT))
cone_bowl_img = load_img("Cone_bowl.png", (220, 150))
cup_station_img = load_img("Cup.png", (150, 300))
char_smile_img = load_img("Char_smile.png", (210, 190))
char_talk_img = load_img("Char_talk.png", (210, 190))

# ==================================================
# SCALE FUNCTION
# ==================================================
def get_scale():
    w, h = screen.get_size()
    scale_w = w / WIDTH
    scale_h = h / HEIGHT
    return min(scale_w, scale_h), w, h

# ==================================================
# CHARACTER & CHAT
# ==================================================
class Character:
    def __init__(self, x, y, sprite_smile, sprite_talk):
        self.x, self.y = x, y
        self.sprite_smile, self.sprite_talk = sprite_smile, sprite_talk
        self.current_sprite = sprite_smile
        self.visible = True
    def draw(self, screen):
        if self.visible:
            screen.blit(self.current_sprite, (self.x, self.y))

class ChatBubble:
    def __init__(self, speaker, font):
        self.speaker, self.font = speaker, font
        self.text = "Welcome to the shop!"
    def draw(self, screen):
        text_surf = self.font.render(self.text, True, (80, 50, 20))
        bubble_w = text_surf.get_width() + 40
        bubble_h = text_surf.get_height() + 20
        bx, by = self.speaker.x - 50, self.speaker.y - 60
        pygame.draw.rect(screen, (255, 255, 255), (bx, by, bubble_w, bubble_h), border_radius=15)
        pygame.draw.rect(screen, (220, 220, 220), (bx, by, bubble_w, bubble_h), 2, border_radius=15)
        screen.blit(text_surf, (bx + 20, by + 10))

# ==================================================
# GAME LOGIC
# ==================================================
FLAVORS = ["vanilla", "chocolate"]
current_order = None
order_string = ""

def generate_order():
    global current_order, order_string
    flavor = random.choice(FLAVORS)
    toppings = []
    order_string = f"One {flavor} cone with no toppings please!"
    current_order = {"base": "Cone", "flavor": flavor, "toppings": toppings}
    return order_string

# ==================================================
# MAIN LOOP
# ==================================================
running = True
order_text = generate_order()

while running:
    dt = clock.tick(60) / 1000
    scale, w, h = get_scale()
    font = pygame.font.SysFont("Comic Sans MS", int(25 * scale), bold=True)

    customer = Character(int(900 * scale), int(150 * scale),
        pygame.transform.scale(char_smile_img, (int(210 * scale), int(190 * scale))),
        pygame.transform.scale(char_talk_img, (int(210 * scale), int(190 * scale)))
    )
    chat_bubble = ChatBubble(customer, font)
    chat_bubble.text = order_text

    RESET_RECT = pygame.Rect(int(1100 * scale), int(650 * scale), int(150 * scale), int(50 * scale))
    SERVE_BUTTON_RECT = pygame.Rect(int(500 * scale), int(650 * scale), int(150 * scale), int(50 * scale))

    CUP_STATION_POS = (int(100 * scale), int(380 * scale))
    CONE_STATION_POS = (int(250 * scale), int(480 * scale))
    TUB_SIZE = (int(220 * scale), int(160 * scale))

    ALL_FLAVOR_POS = {
        "vanilla": (250, 620),
        "chocolate": (500, 620)
    }

    mouse_pos = pygame.mouse.get_pos()

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
        elif event.type == pygame.VIDEORESIZE:
            screen = pygame.display.set_mode(event.size, pygame.RESIZABLE)
        elif event.type == pygame.MOUSEBUTTONDOWN:
            mx, my = event.pos
            if RESET_RECT.collidepoint(mx, my):
                print("RESET clicked!")
                chat_bubble.text = "Everything reset!"
            elif SERVE_BUTTON_RECT.collidepoint(mx, my):
                print("SERVE clicked!")
                chat_bubble.text = generate_order()
            else:
                for f in FLAVORS:
                    tub_rect = pygame.Rect(int(ALL_FLAVOR_POS[f][0] * scale), int(ALL_FLAVOR_POS[f][1] * scale),
                                           int(TUB_SIZE[0]), int(TUB_SIZE[1]))
                    if tub_rect.collidepoint(mx, my):
                        chat_bubble.text = f"You picked {f} flavor!"

    # --- DRAWING ---
    bg_scaled = pygame.transform.scale(bg_img, (w, h))
    screen.blit(bg_scaled, (0, 0))

    cup_scaled = pygame.transform.scale(cup_station_img, (int(150 * scale), int(300 * scale)))
    cone_scaled = pygame.transform.scale(cone_bowl_img, (int(220 * scale), int(150 * scale)))
    screen.blit(cup_scaled, CUP_STATION_POS)
    screen.blit(cone_scaled, CONE_STATION_POS)

    for f in FLAVORS:
        tub_img = load_img(f"{f.capitalize()}_tub.png", TUB_SIZE)
        tub_pos = (int(ALL_FLAVOR_POS[f][0] * scale), int(ALL_FLAVOR_POS[f][1] * scale))
        screen.blit(tub_img, tub_pos)

    pygame.draw.rect(screen, (100, 200, 100), SERVE_BUTTON_RECT, border_radius=15)
    screen.blit(font.render("SERVE", True, (255,255,255)),
                (SERVE_BUTTON_RECT.x + int(30 * scale), SERVE_BUTTON_RECT.y + int(10 * scale)))

    pygame.draw.rect(screen, (220, 60, 60), RESET_RECT, border_radius=15)
    screen.blit(font.render("RESET", True, (255,255,255)),
                (RESET_RECT.x + int(30 * scale), RESET_RECT.y + int(10 * scale)))

    customer.draw(screen)
    chat_bubble.draw(screen)

    pygame.display.flip()

pygame.quit()
sys.exit()
