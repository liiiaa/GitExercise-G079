import pygame
import sys
import os

pygame.init()
clock = pygame.time.Clock()

# Start resolution (boleh ubah untuk test)
WIDTH, HEIGHT = 1280, 720
screen = pygame.display.set_mode((WIDTH, HEIGHT), pygame.RESIZABLE)
pygame.display.set_caption("A Scoop of Spring")

# PATH
CURRENT_DIR = os.path.dirname(os.path.abspath(__file__))
PROJECT_DIR = os.path.dirname(CURRENT_DIR)

# LINK W LIA'S CODE
sys.path.append(os.path.join(PROJECT_DIR, "Lia's codes"))

from ui_layout import load_assets
from ui_layout_screen2 import (
    load_assets as load_level_assets,
    draw_level_selection_ui,
    get_level_ui_layout
)

# link w aliya's codes
sys.path.append(os.path.join(PROJECT_DIR, "Aliya's codes"))

from sound import play_music

# Load assets
game_bg = pygame.image.load(os.path.join(PROJECT_DIR, "Assets", "Main Game Assets", "Game Background.png")).convert()
ui_assets = load_assets()
level_assets = load_level_assets()
next_btn_img = pygame.image.load(os.path.join(PROJECT_DIR, "Assets", "Buttons Assets", "Next button.png")).convert_alpha()
start_button_img = pygame.image.load(os.path.join(PROJECT_DIR, "Assets", "Buttons Assets", "Start button.png")).convert_alpha()

# music tracks

MUSIC_FOLDER = os.path.join(PROJECT_DIR, "Sound Tracks")
MENU_MUSIC = os.path.join(MUSIC_FOLDER, "mainmenu.mp3")

play_music(MENU_MUSIC)

# Game variables
scene = 1
selected_level = 1
current_page = 0
max_levels = 5
unlocked_level = 1

start_btn = next_btn = replay_btn = home_btn = next_btn_result = None

# Helper functions
def draw_text_center(text, font, y, color=(255,255,255)):
    w, h = screen.get_size()
    img = font.render(text, True, color)
    rect = img.get_rect(center=(w//2, y))
    screen.blit(img, rect)

def draw_box(text, rect, color=(255,255,255), text_color=(0,0,0), font=None):
    pygame.draw.rect(screen, color, rect, border_radius=18)
    img = font.render(text, True, text_color)
    text_rect = img.get_rect(center=rect.center)
    screen.blit(img, text_rect)

# Main loop
running = True
while running:
    dt = clock.tick(60) / 1000
    mouse_pos = pygame.mouse.get_pos()
    w, h = screen.get_size()
    scale = min(w / WIDTH, h / HEIGHT)  # maintain proportion

    # Dynamic fonts
    font_big = pygame.font.SysFont(None, int(100 * scale))
    font_medium = pygame.font.SysFont(None, int(40 * scale))
    font_small = pygame.font.SysFont(None, int(30 * scale))

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

        # Handle window resize
        elif event.type == pygame.VIDEORESIZE:
            WIDTH, HEIGHT = event.size
            screen = pygame.display.set_mode((WIDTH, HEIGHT), pygame.RESIZABLE)

        elif event.type == pygame.MOUSEBUTTONDOWN:
            mx, my = event.pos
            if scene == 1 and start_btn and start_btn.collidepoint(mx, my):
                scene = 2
            elif scene == 2 and next_btn_rect and next_btn_rect.collidepoint(mx, my):
                scene = 3
            elif scene == 3:
                layout = get_level_ui_layout()
                start_level = (current_page * 4) + 1
                for i in range(4):
                    clicked_level = start_level + i
                    if clicked_level > max_levels:
                        continue
                    if layout[f'slot_{i}'].collidepoint(mx, my):
                        selected_level = clicked_level
                        scene = 4
                total_pages = (max_levels - 1) // 4
                if layout['next_btn'].collidepoint(mx, my) and current_page < total_pages:
                    current_page += 1
                if layout['prev_btn'].collidepoint(mx, my) and current_page > 0:
                    current_page -= 1
            elif scene == 4 and start_btn_rect and start_btn_rect.collidepoint(mx, my):
                import subprocess
                game_path = os.path.join(PROJECT_DIR, "Lia's codes", "TEST.PY")
                with open(os.path.join(PROJECT_DIR, "current_level.txt"), "w") as file:
                    file.write(str(selected_level))
                subprocess.run([sys.executable, game_path])
            elif scene == 6:
                if replay_btn and replay_btn.collidepoint(mx, my):
                    scene = 3
                elif home_btn and home_btn.collidepoint(mx, my):
                    scene = 1
                elif next_btn_result and next_btn_result.collidepoint(mx, my):
                    selected_level += 1
                    scene = 4

    # SCENE 1 START SCREEN
    if scene == 1:
        scaled_bg = pygame.transform.scale(ui_assets['background'], (w, h))
        screen.blit(scaled_bg, (0, 0))
        logo_rect = ui_assets['logo'].get_rect(center=(w // 2, h // 2 - int(100 * scale)))

        # Scale start button
        start_button_scaled = pygame.transform.scale(start_button_img, (int(500 * scale), int(250 * scale)))
        start_button_rect = start_button_scaled.get_rect(center=(w // 2, h - int(150 * scale)))

        screen.blit(ui_assets['logo'], logo_rect)
        if start_button_rect.collidepoint(mouse_pos):
            hover_surf = start_button_scaled.copy()
            hover_surf.fill((255,255,255,50), special_flags=pygame.BLEND_RGBA_ADD)
            screen.blit(hover_surf, start_button_rect)
        else:
            screen.blit(start_button_scaled, start_button_rect)
        start_btn = start_button_rect

    # SCENE 2 STORY
    elif scene == 2:
        scaled_bg = pygame.transform.scale(ui_assets['background'], (w, h))
        screen.blit(scaled_bg, (0, 0))
        draw_text_center("STORY", font_big, int(100 * scale))
        draw_text_center("Spring has arrived in Bloomberry Town!", font_medium, int(220 * scale))
        draw_text_center("A young girl opened her dream Ice Cream Shop", font_medium, int(300 * scale))
        draw_text_center("to spread happiness through sweet treats.", font_medium, int(380 * scale))
        draw_text_center("Help her serve every customer before the ice cream melts!", font_medium, int(460 * scale))

        # Scale next button
        next_btn_scaled = pygame.transform.scale(next_btn_img, (int(500 * scale), int(250 * scale)))
        next_btn_rect = next_btn_scaled.get_rect(center=(w // 2, h // 2 + int(100 * scale)))
        screen.blit(next_btn_scaled, next_btn_rect)

    # SCENE 3 LEVEL SELECT
    elif scene == 3:
        if level_assets and 'background' in level_assets:
            scaled_bg = pygame.transform.scale(level_assets['background'], (w, h))
            screen.blit(scaled_bg, (0, 0))
        draw_level_selection_ui(screen, level_assets, mouse_pos, current_page)

    # SCENE 4 READY
    elif scene == 4:
        scaled_bg = pygame.transform.scale(game_bg, (w, h))
        screen.blit(scaled_bg, (0, 0))
        draw_text_center(f"LEVEL {selected_level}", font_big, int(200 * scale))
        draw_text_center("Get Ready!", font_medium, int(270 * scale))

        # Scale start button
        start_btn_scaled = pygame.transform.scale(start_button_img, (int(500 * scale), int(250 * scale)))
        start_btn_rect = start_btn_scaled.get_rect(center=(w // 2, h // 2))
        screen.blit(start_btn_scaled, start_btn_rect)

    # SCENE 6 RESULT
    elif scene == 6:
        scaled_bg = pygame.transform.scale(ui_assets['background'], (w, h))
        screen.blit(scaled_bg, (0, 0))
        draw_text_center("RESULT", font_big, int(110 * scale))
        draw_text_center(f"Score: {order_count}/{max_orders}", font_medium, int(180 * scale))
        start_y = int(300 * scale)
        replay_btn = pygame.Rect(w//2 - 160, start_y, 320, 75)
        draw_box("PLAY AGAIN", replay_btn, font=font_medium)
        home_btn = pygame.Rect(w//2 - 160, start_y + int(110 * scale), 320, 75)
        draw_box("HOME", home_btn, font=font_medium)
        next_btn_result = None
        if order_count >= max_orders and selected_level < max_levels:
            next_btn_result = pygame.Rect(w//2 - 160, start_y + int(220 * scale), 320, 75)
            draw_box("NEXT LEVEL", next_btn_result, (200,255,200), font=font_medium)

    pygame.display.flip()

pygame.quit()
sys.exit()